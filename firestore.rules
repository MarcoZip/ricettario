// Regole di sicurezza per Firestore.
// Da incollare nella console Firebase:  Firestore Database > Regole > Pubblica.
// Garantiscono che ogni utente possa leggere/scrivere SOLO i propri dati.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Statistiche accessi: ogni utente scrive solo il proprio documento;
    // solo l'amministratore (per email) può leggerli tutti.
    match /accessStats/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.token.email == 'marcozeta73@gmail.com';
    }
    // Casa condivisa: la lista della spesa condivisa vive sotto households/{code}.
    // Vi accede chiunque sia autenticato E conosca il codice (è il "segreto" condiviso).
    match /households/{hid}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
